# ─────────────────────────────────────────────────────────────────────────────
#  DAoC 3v3 Matchmaking Bot — .env.example
#  Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# Required ────────────────────────────────────────────────────────────────────

DISCORD_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Channel where match proposals ("match found, open /my_panel") are posted.
MATCHMAKING_CHANNEL_ID=123456789

# Channel where match-started announcements are broadcast to everyone.
BROADCAST_CHANNEL_ID=987654321

# Optional ────────────────────────────────────────────────────────────────────

# Exact name of the Discord role required to use bot commands (case-sensitive).
# Default: "Team Leader"
# TEAM_LEADER_ROLE_NAME=Team Leader

# Seconds both leaders have to accept a proposed match (default: 120).
# MATCH_ACCEPT_TIMEOUT=120

# Python logging level: DEBUG | INFO | WARNING | ERROR (default: INFO).
# LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
#  Discord server setup
# ─────────────────────────────────────────────────────────────────────────────
#
#  Roles:
#    Create a "Team Leader" role (or whatever name you set above).
#    Assign it to every team captain before the event.
#
#  Channels:
#    #matchmaking   — restricted to Team Leaders (and the bot).
#                     The bot posts match-found pings here.
#    #match-results — visible to everyone.
#                     The bot broadcasts match-started and match-ended here.
#
#  Channel permissions for #matchmaking:
#    @everyone      → View Channel: ❌
#    Team Leader    → View Channel: ✅,  Send Messages: ❌  (read-only for leaders)
#    Bot            → View Channel: ✅,  Send Messages: ✅
#
#  Channel permissions for #match-results:
#    @everyone      → View Channel: ✅,  Send Messages: ❌
#    Bot            → View Channel: ✅,  Send Messages: ✅
#
# ─────────────────────────────────────────────────────────────────────────────
#  Flow summary
# ─────────────────────────────────────────────────────────────────────────────
#
#  1. Leader runs /register_team  → gets ephemeral panel (only they see it)
#  2. Leader clicks ✅ Ready      → panel updates to show ⏸️ Unready
#  3. Match found                 → ping in #matchmaking tagging both leaders
#                                   "open /my_panel to accept"
#  4. Each leader runs /my_panel  → sees Accept / Decline buttons (ephemeral)
#  5. Both accept                 → #match-results broadcast: "MATCH STARTED!"
#                                   tagging both captains
#  6. Match ends (either leader   → #match-results broadcast: "Match Over"
#     clicks 🏁 Match Ended)        tagging both captains
#  7. Both leaders can /my_panel  → back to ✅ Ready
