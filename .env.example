# ─────────────────────────────────────────────────────────────────────────────
#  DAoC 3v3 Matchmaking Bot — .env.example
#  Copy this file to .env and fill in the values for local development.
#  On Railway, set these as environment variables in the project dashboard.
# ─────────────────────────────────────────────────────────────────────────────

# Required ────────────────────────────────────────────────────────────────────

DISCORD_TOKEN=your_bot_token_here

# PostgreSQL connection string.
# On Railway: this is injected automatically as DATABASE_URL when you attach
# a Postgres service to your project (Railway → project → + New → Database →
# Add PostgreSQL).  You do NOT need to set this manually on Railway.
# For local development: spin up a local Postgres instance and set this.
DATABASE_URL=postgresql://user:password@localhost:5432/daoc_bot

# Optional — default channel IDs ──────────────────────────────────────────────
#
# These pre-fill the /start_event form for single-guild deployments.
# For multi-guild bots, leave these unset and supply channel IDs per-event
# via /start_event.
#
# Channel where match proposals and private leader threads are created.
# MATCHMAKING_CHANNEL_ID=1234567890123456789
#
# Channel where match-started/ended announcements are broadcast to everyone.
# BROADCAST_CHANNEL_ID=1234567890123456789

# Optional ────────────────────────────────────────────────────────────────────

# Kill switch — set to anything other than "true" to take the bot offline
# without stopping the Railway service. Default: true (bot runs normally).
# RUN_BOT=true

# Exact name of the Discord role required to use bot commands (case-sensitive).
# Default: "Team Leader"
# TEAM_LEADER_ROLE_NAME=Team Leader

# Python logging level: DEBUG | INFO | WARNING | ERROR (default: INFO).
# LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────────
#  Railway deployment — quick start
# ─────────────────────────────────────────────────────────────────────────────
#
#  1. Create a new Railway project.
#  2. Add a PostgreSQL service (Railway → + New → Database → Add PostgreSQL).
#     Railway will inject DATABASE_URL automatically.
#  3. Add your bot service (deploy from GitHub repo or Railway CLI).
#  4. Set DISCORD_TOKEN in the bot service's environment variables.
#  5. Railway builds via nixpacks and starts with: python -m daoc_bot
#
#  The bot runs as a "worker" (no HTTP port), so disable Railway's port health
#  check by ensuring the Procfile declares:  worker: python -m daoc_bot
#
# ─────────────────────────────────────────────────────────────────────────────
#  Local development quick start
# ─────────────────────────────────────────────────────────────────────────────
#
#  1. Set DISCORD_TOKEN and DATABASE_URL above.
#  2. Run:  python -m daoc_bot
#  3. An admin runs /start_event in Discord to configure and start an event.
#
#  After the event is started, team leaders with the "Team Leader" role can:
#    /register_team   → get a private thread with live buttons
#    /queue_status    → see who is in queue
#    /match_status    → see active matches
#
#  Admins can:
#    /set_config      → update event settings mid-event
#    /event_status    → view current event configuration
#    /end_event       → close the event and reset all state
#    /leaderboard     → view MMR rankings
#    /admin_*         → manage teams and matches
# ─────────────────────────────────────────────────────────────────────────────
